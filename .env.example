# Task Hounds Environment Configuration
# Copy this file to .env and fill in your actual values

# --- Database ---
# SQLite (default for development)
POWER_TEAMS_DB=core/db/power_teams.db

# --- OpenCode Configuration ---
# Run installation.cmd to install Task Hounds' managed OpenCode runtime.
# Task Hounds does not use external OpenCode binary overrides.

# --- Agent Settings ---
# Reuse OpenCode sessions for context continuity
# POWER_TEAMS_REUSE_OPENCODE_SESSIONS=true

# Enable TMUX idle detection: replaces time-based checks with actual
# agent idle detection (checks for "Ask anything" + "Sisyphus" in pane)
# POWER_TEAMS_USE_TMUX_IDLE=1

# --- Timeouts ---
# Max silence before killing an agent (seconds)
# POWER_TEAMS_SILENCE_TIMEOUT=480

# Absolute wall-clock timeout per attempt (seconds)
# POWER_TEAMS_HARD_TIMEOUT=1200

# --- GraphFlow Capacity ---
# By default Task Hounds allows up to 10 independent GraphFlow jobs.
# You can change these from the Background Servers modal. Environment
# variables are still supported for scripted deployments:
# TASK_HOUNDS_GRAPHFLOW_WORKER_COUNT=10
# TASK_HOUNDS_MAX_ACTIVE_JOBS=10
# POWER_TEAMS_OPENCODE_CONCURRENCY=10
#
# New jobs are rejected before they start when active jobs, CPU, or memory are
# over the configured limits. CPU/memory checks use psutil.
# TASK_HOUNDS_MAX_CPU_PERCENT=90
# TASK_HOUNDS_MAX_MEMORY_PERCENT=90
#
# Cold starts do not silently resume old GraphFlow jobs by default. Set this
# only if you want unfinished jobs to continue automatically after reboot.
# TASK_HOUNDS_RESUME_ACTIVE_JOBS_ON_START=false

# --- API Security ---
# The API only accepts requests with a localhost Host header and
# localhost browser origins by default. If you expose it on your LAN or
# via Tailscale, add the extra hostnames/origins explicitly:
# TASK_HOUNDS_ALLOWED_HOSTS=my-machine.tailnet-name.ts.net
# TASK_HOUNDS_CORS_ORIGINS=https://my-machine.tailnet-name.ts.net

# Optional API key. When set, every /api request (except /api/health)
# must send a matching X-API-Key header. Recommended for any
# non-localhost exposure. Generate one:
#   python -c "import secrets; print(secrets.token_hex(32))"
# API_SECRET_KEY=

# --- API Keys (Optional - only needed for specific backends) ---
# At least one provider key is required to run the agent loop.

# MiniMax API Key (for minimax-coding-plan provider, the default)
# OPENCODE_API_KEY_MINIMAX=your_minimax_api_key_here

# Moonshot Kimi API Key (for kimi-coding-plan provider — Kimi K3 etc.)
# Get one at https://platform.kimi.ai/console/api-keys
# OPENCODE_API_KEY_KIMI=your_kimi_api_key_here

# To run the whole pack on Kimi K3, also uncomment:
# TASK_HOUNDS_OPENCODE_MODEL=kimi-coding-plan/kimi-k3

# Alibaba Cloud Model Studio / Bailian API Key (for bailian-coding-plan provider)
# OPENCODE_API_KEY_BAILIAN=your_bailian_api_key_here

# Anthropic API Key (for OpenClaw backend)
# ANTHROPIC_API_KEY=your_anthropic_api_key_here

# --- News App (if using) ---
# See news-app/.env.example for news-app specific configuration
